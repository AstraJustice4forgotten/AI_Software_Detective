import os
import hashlib
import json
import schedule
import time
from fastapi import FastAPI, UploadFile, File
from loguru import logger
import requests
import httpx
from pydantic import BaseModel
import openai
from tenacity import retry, wait_fixed, stop_after_attempt
from sqlalchemy import create_engine, Column, String, Float, Table, MetaData
from sqlalchemy.orm import sessionmaker
from PIL import Image
import psutil
import yaml
import aiofiles

# -------------------------
# Config & API keys
# -------------------------
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
WAPPALYZER_API_KEY = os.getenv("WAPPALYZER_API_KEY")
SNYK_TOKEN = os.getenv("SNYK_TOKEN")

openai.api_key = OPENAI_API_KEY

# -------------------------
# Database setup
# -------------------------
engine = create_engine("sqlite:///fingerprints.db")
metadata = MetaData()
fingerprints_table = Table(
    "fingerprints", metadata,
    Column("name", String, primary_key=True),
    Column("hash", String),
    Column("similarity", Float)
)
metadata.create_all(engine)
Session = sessionmaker(bind=engine)
session = Session()

# -------------------------
# FastAPI setup
# -------------------------
app = FastAPI(title="AI Software Detective 💅🔥")

# -------------------------
# Utility functions
# -------------------------
def hash_file(file_path):
    hasher = hashlib.sha256()
    with open(file_path, "rb") as f:
        while chunk := f.read(8192):
            hasher.update(chunk)
    return hasher.hexdigest()

def compare_hashes(hash1, hash2):
    # Simple similarity comparison
    matches = sum(a == b for a, b in zip(hash1, hash2))
    return matches / max(len(hash1), len(hash2))

@retry(wait=wait_fixed(3), stop=stop_after_attempt(5))
def call_openai(prompt):
    response = openai.Completion.create(
        model="text-davinci-003",
        prompt=prompt,
        temperature=0.7,
        max_tokens=150
    )
    return response.choices[0].text.strip()

# -------------------------
# API Models
# -------------------------
class WebsiteScanRequest(BaseModel):
    url: str

class RepoScanRequest(BaseModel):
    repo_url: str

# -------------------------
# API Endpoints
# -------------------------
@app.post("/analyze/website/")
async def analyze_website(request: WebsiteScanRequest):
    url = request.url
    headers = {"x-api-key": WAPPALYZER_API_KEY}
    try:
        resp = requests.get(f"https://api.wappalyzer.com/lookup/v2/?urls={url}", headers=headers)
        data = resp.json()
        summary = call_openai(f"Give a sassy summary of tech stack for: {data}")
        return {"url": url, "stack": data, "summary": summary}
    except Exception as e:
        logger.error(f"Website scan failed: {e}")
        return {"error": str(e)}

@app.post("/analyze/repo/")
async def analyze_repo(request: RepoScanRequest):
    repo = request.repo_url
    headers = {"Authorization": f"token {SNYK_TOKEN}"}
    try:
        resp = requests.get(f"https://snyk.io/api/v1/test/github/{repo}", headers=headers)
        data = resp.json()
        summary = call_openai(f"Sassy repo vulnerability summary for: {data}")
        return {"repo": repo, "results": data, "summary": summary}
    except Exception as e:
        logger.error(f"Repo scan failed: {e}")
        return {"error": str(e)}

@app.post("/analyze/binary/")
async def analyze_binary(file: UploadFile = File(...)):
    file_path = f"/tmp/{file.filename}"
    async with aiofiles.open(file_path, 'wb') as out_file:
        content = await file.read()
        await out_file.write(content)
    file_hash = hash_file(file_path)
    similar = []
    for record in session.query(fingerprints_table).all():
        sim = compare_hashes(file_hash, record.hash)
        if sim > 0.7:
            similar.append({"name": record.name, "similarity": sim})
    summary = call_openai(f"Sassy binary scan summary for {file.filename}. Matches: {similar}")
    return {"file_name": file.filename, "fingerprint_hash": file_hash, "similar_apps": similar, "summary": summary}

